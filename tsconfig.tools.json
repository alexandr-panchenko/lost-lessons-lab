{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2023", "DOM"],
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tools.tsbuildinfo",
    "types": [
      "node",
      "@cloudflare/workers-types",
      "@cloudflare/vitest-pool-workers/types"
    ]
  },
  "include": [
    "eslint.config.js",
    "fixtures",
    "playwright.config.ts",
    "scripts",
    "src/client/canvas/stroke-simplify.ts",
    "src/client/canvas/stroke-render.ts",
    "src/shared",
    "src/simulations",
    "src/worker",
    "tests",
    "vite.config.ts",
    "vitest.*.config.ts",
    "worker-configuration.d.ts"
  ]
}
