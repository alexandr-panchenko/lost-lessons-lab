# Copy this file to .dev.vars for local Cloudflare development.
# Never commit .dev.vars or real values.

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
AI_ENABLED=true
ROOM_TOKEN_PEPPER=
APP_ENV=development
PUBLIC_APP_ORIGIN=http://localhost:5173

# AI execution defaults. Keep configurable so live evaluation can tune them.
AI_TIMEOUT_MS=24000
AI_MAX_RETRIES=1
AI_ROOM_LIMIT_PER_HOUR=60
AI_IP_LIMIT_PER_HOUR=120
ROOM_CREATE_IP_LIMIT_PER_HOUR=60

# Upload limits.
MAX_MEDIA_BYTES=8388608
MAX_MEDIA_EDGE_PX=4096
ANALYSIS_MEDIA_EDGE_PX=2048

# Optional production metadata.
GIT_COMMIT_SHA=
SUBMISSION_TAG=
