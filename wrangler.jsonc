{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "lost-lessons-lab",
  "main": "src/worker/index.ts",
  "compatibility_date": "2026-07-21",
  "assets": {
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"],
  },
  "vars": {
    "OPENAI_MODEL": "gpt-5.6",
    "AI_ENABLED": "false",
    "APP_ENV": "development",
    "PUBLIC_APP_ORIGIN": "http://localhost:5173",
    "AI_TIMEOUT_MS": "24000",
    "AI_MAX_RETRIES": "1",
    "AI_ROOM_LIMIT_PER_HOUR": "60",
    "AI_IP_LIMIT_PER_HOUR": "120",
    "ROOM_CREATE_IP_LIMIT_PER_HOUR": "60",
    "MAX_MEDIA_BYTES": "8388608",
    "MAX_MEDIA_EDGE_PX": "4096",
    "ANALYSIS_MEDIA_EDGE_PX": "2048",
    "GIT_COMMIT_SHA": "",
    "SUBMISSION_TAG": "",
  },
  "secrets": {
    "required": ["OPENAI_API_KEY", "ROOM_TOKEN_PEPPER"],
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "ROOMS",
        "class_name": "RoomDurableObject",
      },
    ],
  },
  "exports": {
    "RoomDurableObject": {
      "type": "durable-object",
      "storage": "sqlite",
    },
  },
  "r2_buckets": [
    {
      "binding": "MEDIA",
      "bucket_name": "lost-lessons-lab-media",
    },
  ],
  "observability": {
    "enabled": true,
  },
}
