{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "lost-lessons-lab",
  "main": "src/worker/index.ts",
  "compatibility_date": "2026-07-21",
  "workers_dev": true,
  "preview_urls": false,
  "assets": {
    "not_found_handling": "single-page-application",
    "run_worker_first": [
      "/",
      "/judge",
      "/water",
      "/speed",
      "/structure",
      "/api/*",
    ],
  },
  "vars": {
    "OPENAI_MODEL": "gpt-5.6",
    "AI_ENABLED": "true",
    "APP_ENV": "production",
    "PUBLIC_APP_ORIGIN": "https://lost-lessons-lab.sanocks.workers.dev",
    "AI_TIMEOUT_MS": "24000",
    "AI_MAX_RETRIES": "1",
    "AI_ROOM_LIMIT_PER_HOUR": "60",
    "AI_IP_LIMIT_PER_HOUR": "120",
    "ROOM_CREATE_IP_LIMIT_PER_HOUR": "60",
    "MAX_MEDIA_BYTES": "8388608",
    "MAX_MEDIA_EDGE_PX": "4096",
    "ANALYSIS_MEDIA_EDGE_PX": "2048",
    "GIT_COMMIT_SHA": "",
    "SUBMISSION_TAG": "",
  },
  "secrets": {
    "required": ["ROOM_TOKEN_PEPPER", "OPENAI_API_KEY"],
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "ROOMS",
        "class_name": "RoomDurableObject",
      },
    ],
  },
  "exports": {
    "RoomDurableObject": {
      "type": "durable-object",
      "storage": "sqlite",
    },
  },
  "r2_buckets": [
    {
      "binding": "MEDIA",
      "bucket_name": "lost-lessons-lab-media",
    },
  ],
  "ratelimits": [
    {
      "name": "ROOM_CREATE_RATE_LIMITER",
      "namespace_id": "2026072101",
      "simple": {
        "limit": 60,
        "period": 60,
      },
    },
    {
      "name": "AI_REQUEST_RATE_LIMITER",
      "namespace_id": "2026072102",
      "simple": {
        "limit": 120,
        "period": 60,
      },
    },
  ],
  "observability": {
    "enabled": true,
  },
}
