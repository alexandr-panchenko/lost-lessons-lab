{
  "name": "lost-lessons-lab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b --pretty false && WRANGLER_LOG_PATH=/tmp/lost-lessons-wrangler.log vite build && bun run scripts/finalize-build.ts",
    "audit:secrets": "bun run scripts/secret-audit.ts",
    "cf-typegen": "WRANGLER_LOG_PATH=/tmp/lost-lessons-wrangler.log wrangler types --strict-vars=false",
    "deploy": "bun run build && WRANGLER_LOG_PATH=/tmp/lost-lessons-wrangler.log wrangler deploy",
    "dev": "WRANGLER_LOG_PATH=/tmp/lost-lessons-wrangler.log vite",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "smoke:prod": "bun run scripts/smoke-prod.ts",
    "smoke:security:prod": "bun run scripts/verify-production-security.ts",
    "smoke:ai:prod": "bun run scripts/verify-production-ai.ts",
    "smoke:hero:prod": "bun run scripts/verify-production-hero.ts",
    "smoke:water:prod": "bun run scripts/verify-production-water.ts",
    "smoke:speed:prod": "bun run scripts/verify-production-speed.ts",
    "smoke:structure:prod": "bun run scripts/verify-production-structure.ts",
    "smoke:fallback:prod": "bun run scripts/verify-production-fallback.ts",
    "smoke:accessibility:prod": "bun run scripts/verify-production-accessibility.ts",
    "smoke:r0:prod": "bun run scripts/verify-rescue-r0.ts",
    "smoke:r2:prod": "bun run scripts/verify-rescue-r2.ts",
    "capture:r2": "bun run scripts/capture-rescue-r2.ts",
    "capture:final-bridge-rc": "bun run scripts/capture-final-bridge-rc.ts",
    "capture:video:draft": "bun run scripts/capture-submission-video.ts",
    "build:video:draft": "bash scripts/build-submission-video.sh",
    "verify:media": "bun run scripts/verify-submission-media.ts",
    "test:e2e": "WRANGLER_LOG_PATH=/tmp/lost-lessons-wrangler.log playwright test",
    "test:integration": "WRANGLER_LOG_PATH=/tmp/lost-lessons-wrangler.log vitest run --config vitest.integration.config.ts && WRANGLER_LOG_PATH=/tmp/lost-lessons-wrangler.log vitest run --config vitest.workflow.config.ts",
    "test:live-ai": "vitest run --config vitest.live-ai.config.ts --reporter=verbose --disableConsoleIntercept",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "typecheck": "tsc -b --pretty false",
    "validate": "bun run format:check && bun run lint && bun run typecheck && bun run test:unit && bun run test:integration && bun run build && bun run audit:secrets && bun run test:e2e"
  },
  "dependencies": {
    "hono": "4.12.31",
    "pixi.js": "8.19.0",
    "planck": "1.5.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.45.1",
    "@cloudflare/vitest-pool-workers": "0.18.6",
    "@cloudflare/workers-types": "5.20260721.1",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@types/node": "24.13.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "10.7.0",
    "prettier": "3.9.5",
    "typescript": "6.0.2",
    "typescript-eslint": "8.65.0",
    "vite": "8.1.5",
    "vitest": "4.1.10",
    "wrangler": "4.112.0"
  },
  "engines": {
    "bun": ">=1.2.5"
  }
}
